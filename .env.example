# ============================================================
# Optima Control HUB — переменные окружения
# Скопируй в .env и заполни нужные значения
# ============================================================

# Порт сервера (Railway устанавливает автоматически)
PORT=3000

# Окружение: "production" | "development"
NODE_ENV=development

# ── Firebase ─────────────────────────────────────────────────
# Firebase конфиг уже вшит в src/firebase.ts (публичный)
# Если хочешь использовать env vars — перепиши firebase.ts
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
